SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-your-backend-only-service-role-key
SUPABASE_JWT_SECRET=replace-with-your-supabase-jwt-secret
SUPABASE_STORAGE_BUCKET=markdown-outputs
FRONTEND_ORIGIN=http://127.0.0.1:3000
MAX_ACTIVE_CONVERSIONS=3
MAX_PENDING_CONVERSIONS=10
CONVERSION_TIMEOUT_SECONDS=300
PDF_MAX_BYTES=26214400
TEMP_CONVERSION_DIR=/tmp/conversions
